# =============================================================
# VoicePaint Backend 环境变量模板
# 复制本文件为 .env 并填入真实值，**不要把 .env 提交到 git**
# =============================================================

# --- 服务 ---
NODE_ENV=development
PORT=3000
API_PREFIX=api

# --- MongoDB ---
# 本地: mongodb://localhost:27017/voicepaint
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/voicepaint
MONGODB_URI=

# --- JWT 双 Token 鉴权 ---
# ⚠️ 生产环境务必使用足够强度的随机串（建议 openssl rand -hex 32）
JWT_ACCESS_SECRET=replace-me-with-strong-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-me-with-strong-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- 火山引擎（火山方舟 Seedream + 火山 ASR 通用凭证）---
# 注册: https://www.volcengine.com/
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_SECRET_KEY=
# 火山方舟 API Key（在「API Key 管理」创建）
VOLC_ARK_API_KEY=
# 绘图模型 ID（默认 doubao-seedream-5-0-260128）
VOLC_ARK_MODEL_ID=doubao-seedream-5-0-260128

# --- 腾讯云 ASR（备用引擎，可选）---
# 开通: https://cloud.tencent.com/product/asr
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_APP_ID=

# --- 硅基流动 DeepSeek-V3 ---
# 注册: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# --- 阿里云 OSS（用于持久化音频 + 生成图片）---
# 开通: https://www.aliyun.com/product/oss
ALIYUN_OSS_REGION=oss-cn-shanghai
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=voicepaint
